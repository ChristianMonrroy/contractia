# ContractIA v6 — Configuración
# Copia como .env y ajusta los valores

LLM_PROVIDER=vertexai # opciones: ollama, vertexai

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_FALLBACK=qwen3:8b
OLLAMA_TEMPERATURE=0.6
OLLAMA_NUM_CTX=16384
OLLAMA_NUM_PREDICT=8192
OLLAMA_TIMEOUT=600

VERTEXAI_PROJECT=agenteia-471917 #Cambiiar por el ID de tu proyecto en Google Cloud
VERTEXAI_LOCATION=us-central1
VERTEXAI_MODEL=gemini-2.5-pro
VERTEXAI_FALLBACK=gemini-2.5-pro
VERTEXAI_TEMPERATURE=0.0
VERTEXAI_MAX_OUTPUT_TOKENS=8192
VERTEXAI_EMBEDDING_MODEL=text-embedding-004
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

RAG_ENABLED=true
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_CHUNK_SIZE=1500
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=3

CONTRACTS_DIR=contracts
OUTPUT_DIR=output
REPORT_FILENAME=informe_auditoria_contrato.md

ENABLE_LLM=true
LOG_LEVEL=INFO
